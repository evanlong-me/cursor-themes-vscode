{
  "name": "cursor-themes",
  "displayName": "Cursor Themes for VS Code",
  "description": "A faithful recreation of the Cursor editor's signature look for VS Code — Cursor Dark, Cursor Light, Dark Midnight, Dark High Contrast, and Light Colorblind.",
  "version": "1.0.2",
  "publisher": "evanlong",
  "icon": "icon.png",
  "author": {
    "name": "Evan Long",
    "url": "https://github.com/evanlong-me"
  },
  "engines": {
    "vscode": "*"
  },
  "categories": [
    "Themes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/evanlong-me/cursor-themes-vscode.git"
  },
  "contributes": {
    "themes": [
      {
        "label": "Cursor Dark Midnight",
        "uiTheme": "vs-dark",
        "path": "./themes/cursor-dark-midnight-color-theme.json"
      },
      {
        "label": "Cursor Dark High Contrast",
        "uiTheme": "hc-black",
        "path": "./themes/cursor-dark-hc-color-theme.json"
      },
      {
        "label": "Cursor Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/cursor-dark-color-theme.json"
      },
      {
        "label": "Cursor Light",
        "uiTheme": "vs",
        "path": "./themes/cursor-light-color-theme.json"
      },
      {
        "label": "Cursor Light Colorblind (Beta)",
        "uiTheme": "vs",
        "path": "./themes/cursor-light-colorblind-color-theme.json"
      }
    ]
  }
}
